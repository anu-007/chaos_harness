# Shared environment for the FarLabs stack. Copy to `.env` (gitignored) before `make up`:
#   cp .env.example .env
# docker-compose loads these into the coordinators, workers, and the harness (make test)
# via `env_file`. Per-service identity (COORD_ID for c1/c2/c3, WORKER_ID for w1..w5) is NOT
# here — it stays inline in docker-compose.yml because each container needs a distinct value.
#
# Non-Docker (local) runs: coordinator/worker main() and tests/conftest.py load this .env via
# python-dotenv. The hostnames below (`postgres`, `redis`) only resolve on the compose network,
# so for a local process EXPORT your own DATABASE_URL / REDIS_URL (e.g. pointing at localhost)
# before launching — an already-set env var always wins over this file.

# Postgres — the single source of truth. Host is the compose service name `postgres`.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/farlabs

# Redis — optimization only (dispatch wakeup pub/sub + /stats counters). DB 0.
REDIS_URL=redis://redis:6379/0

# Lease TTL in ms. Long jobs survive via heartbeat renewal; the reaper requeues past this.
LEASE_TTL_MS=10000

# Workers connect to the coordinators through the nginx LB over WebSocket.
LB_WS_URL=ws://lb:8080

# Per-worker concurrency. 5 workers x 16 = 80 slots to drain the 50 jobs/s submit rate.
WORKER_CONCURRENCY=16
